{
  "family": "farmer-assist-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::REPLACE_ACCOUNT:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "farmer-assist-backend",
      "image": "REPLACE_IMAGE_URI",
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/farmer-assist-backend",
          "awslogs-region": "REPLACE_REGION",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
